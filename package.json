{
  "name": "ncaa-auction-standings-app",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "npm --prefix frontend run build",
    "build:web": "npm --prefix frontend run build",
    "start": "node backend/server.js",
    "start:backend": "npm --prefix backend run start",
    "install:all": "npm install && npm --prefix frontend install && npm --prefix backend install",
    "ios:add": "npx cap add ios",
    "ios:sync": "npm run build:web && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:run": "npm run ios:sync && npx cap run ios"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "@capacitor/ios": "^7.4.2"
  }
}
